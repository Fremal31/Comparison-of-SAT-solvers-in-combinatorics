{
  "metrics_measured": {
    "problem": true,
    "formulator": true,
    "breaker": true,
    "solver": true,
    "parent_problem": true,
    
    "status": true,

    "cpu_usage_avg": true,
    "cpu_usage_max": true,
    "memory_peak_mb": true,
    "time": true,
    "cpu_time": true,
    "total_time": true,
    "exit_code": true,

    "conversion_time": true,
    "conversion_cpu_time": true,
    "conversion_memory_mb": true,

    "break_time": true,
    "break_cpu_time": true,
    "break_memory_mb": true,

    "cores_used": true,

    "restarts": true,
    "conflicts": true,
    "decisions": true,
    "propagations": true,

    "nodes": true,
    "iterations": true,
    "objective": true,
    
    "error": true,
    "stderr": true,
    "stdout": false
  },
  "triplets": [
    {
      "problem": "hamilton_2",
      "formulator": "hamilton_SAT",
      "breaker": "breakid",
      "solver": "cadical_cmd"
    },
    {
      "problem": "hamilton_2",
      "formulator": "hamilton_SAT"
    },
    {
      "without_converter": "hamilton_without_converter"
    }
  ],
  "formulators": {
    "hamilton_SAT": {"type": "SAT", "cmd": "../formulator/hamilton_SAT.py", "enabled": true, "options": ["-", "<","{input}"], "output_mode": "stdout"},
    "hamilton_ILP": {"type": "ILP", "cmd": "../formulator/hamilton_ILP.py", "enabled": true, "options": ["-", "<","{input}"], "output_mode": "stdout"},
    "hamilton_SMT": {"type": "SMT", "cmd": "../formulator/dummy_formulator.py", "enabled": true, "options": ["{input}", "{output}"], "output_mode": "stdout"}
  },
  "breakers": {
    "breakid": {"type": "SAT", "cmd": "../breakid/breakid", "enabled": true, "options": [], "threads": 1}
  },
  "solvers": {
    "Glucose": {"type": "SAT", "cmd": "../solver_exec/glucose_static", "enabled": false, "parser": "Glucose"},
    "cadical_cmd": {"type": "SAT", "cmd": "cadical", "enabled": true, "options": ["-f"], "threads": 1},
    "kissat_cmd": {"type": "SAT", "cmd": "kissat", "enabled": true, "options": ["-n", "{input}"], "parser": "Kissat", "threads": 1},
    "isasat": {"type": "SAT", "cmd": "../solver_exec/isasat", "enabled": true, "options": [], "parser": "Kissat"},
    "yalsat": {"type": "SAT", "cmd": "../solver_exec/yalsat", "enabled": false, "options": [], "parser": "Kissat"},

    "highs_cmd": {"type": "ILP", "cmd": "highs", "enabled": true, "options": [], "parser": "Highs"},
    "scip_cmd": {"type": "ILP", "cmd": "scip", "enabled": true, "options": ["-f", "{input}"]},

    "z3_cmd": {"type": "SMT", "cmd": "../solver_exec/hamilton_Z3_from_raw.py", "enabled": false, "options": []}
  },
  "files": {
    "hamilton_1": {"path": "../examples/hamilton_small.g6"},
    "hamilton_2": {"path": "../examples/graph1.g6", "enabled": true}
  },
  "without_converter": {
    "hamilton_without_converter": {"path": "../examples/hamilton/hamilton_biggood2.txt", "type": "SAT", "enabled": false},
    "vertex_without_converter": {"path": "../examples/vertexColoring/good3_951.txt", "type": "SAT", "enabled": false},
    "test_lp_without_converter": {"path": "../examples/test.lp", "type": "ILP", "enabled": false}
  },
  "triplet_mode": false,
  
  "threading": {
    "max_threads": 12,
    "allowed_cores": [0, 2, 3, 4, 5, 6],
    "ensure_cleanup_on_crash": false
  },

  "timeout": 100,

  "working_dir": "/tmp/solver_comparison",
  "delete_working_dir": true,
  "use_hardlink": true,
  
  "results_csv": "../results/multi_solver_results.csv",
  "results_json": "../results/multi_solver_results.json",
  "results_jsonl": "../results/multi_solver_results.jsonl",

  "visualization": {
    "enabled": true,
    "output_dir": "../results/plots"
  }

}
